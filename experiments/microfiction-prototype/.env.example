# 复制为 .env 后填入。智谱 GLM-4-Flash 免费 key: https://bigmodel.cn
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=
LLM_MODEL=glm-4-flash
LLM_PROVIDER=Zhipu

# 切换到其他 OpenAI-compatible 提供方时改这几个变量即可：
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini             LLM_PROVIDER=OpenAI
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1          LLM_MODEL=deepseek-chat           LLM_PROVIDER=DeepSeek
# Moonshot:  LLM_BASE_URL=https://api.moonshot.cn/v1           LLM_MODEL=moonshot-v1-8k          LLM_PROVIDER=Moonshot
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1        LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free  LLM_PROVIDER=OpenRouter
